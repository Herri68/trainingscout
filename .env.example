# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_YOUR_KEY
EMAIL_FROM=TrainingScout <noreply@yourdomain.com>

# Cron auth (Vercel Cron mengirim Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate_random_string_min_32_chars

# V2 WhatsApp via WAHA managed (mis. Sumopod).
# WHATSAPP_ENABLED=true membuka opsi channel WhatsApp di UI create-batch + mengaktifkan webhook.
WHATSAPP_ENABLED=false
# Nomor WAHA yang dipakai untuk generate link wa.me (format internasional tanpa +).
WAHA_NUMBER=628123456789
# Base URL + API key dari Sumopod WAHA dashboard.
WAHA_BASE_URL=https://your-instance.sumopod.cloud
WAHA_API_KEY=
WAHA_SESSION_NAME=default
# HMAC Key yang diset di WAHA dashboard → Webhooks → HMAC Key.
# Vercel verifikasi header X-Webhook-Hmac (sha512 hex) menggunakan secret ini.
WAHA_WEBHOOK_HMAC_SECRET=
# GROQ_API_KEY dipakai mulai Phase 4 (voice transcribe Whisper). Phase 1-3 boleh kosong.
GROQ_API_KEY=

# WA Magic Link Login (single trainer, internal-only).
# Email trainer satu-satunya yang valid (case-insensitive). Tanpa ini, route auto-fallback ke email path.
TRAINER_EMAIL=
# JID WAHA tujuan magic link (format sesuai payload `from` webhook WAHA, mis. 6281234567890@c.us atau <id>@lid).
TRAINER_WA_JID=
