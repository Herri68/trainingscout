# Disalin jadi `.env` di VPS (sebelahan dengan docker-compose.yml).

# WAHA API key — pakai random string panjang, dipakai juga oleh app Vercel (WAHA_API_KEY).
WAHA_API_KEY=replace_with_random_secret

# URL Vercel app yang menerima forward dari debouncer.
FORWARD_URL=https://your-app.vercel.app/api/wa/webhook

# Shared HMAC secret — sama dengan WAHA_WEBHOOK_HMAC_SECRET di Vercel env.
FORWARD_HMAC_SECRET=replace_with_random_secret
